{
  "title": "Infraestructura - Crypto Exchange",
  "uid": "infra-001",
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "CPU por contenedor (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 2,
      "title": "Memoria por contenedor (MB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 3,
      "title": "CPU del host (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU Host",
          "datasource": "Prometheus"
        }
      ]
    },
    {
      "id": 4,
      "title": "RAM del host (GB)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024 / 1024",
          "legendFormat": "RAM Usada",
          "datasource": "Prometheus"
        }
      ]
    }
  ],
  "schemaVersion": 36,
  "version": 1
}
